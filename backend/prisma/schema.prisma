generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  LEADERSHIP
  ESTIMATOR
  PM
  READ_ONLY
}

enum PipelineStage {
  LEAD
  REVIEWING_ITB
  GO_NO_GO
  ESTIMATING
  BID_SUBMITTED
  AWAITING_DECISION
  WON
  LOST
  NO_BID
  WITHDRAWN
}

enum CustomerType {
  GC
  DEVELOPER
  GOVERNMENT
  OWNER_DIRECT
}

enum RelationshipTier {
  PLATINUM
  GOLD
  SILVER
  NEW
}

enum BacklogStatus {
  ACTIVE
  COMPLETE
  ON_HOLD
  CANCELLED
}

enum GoNoGoDecision {
  GO
  NO_GO
  DEFER
}

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique
  fullName      String
  email         String?   @unique
  passwordHash  String
  role          Role
  isActive      Boolean   @default(true)
  mustChangePwd Boolean   @default(true)
  failedLoginAttempts Int  @default(0)
  lockedUntil   DateTime?
  tokenVersion  Int        @default(0)
  totpSecret    String?
  totpEnabled   Boolean    @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isArchived    Boolean   @default(false)

  assignedOpportunitiesEstimator Opportunity[] @relation("EstimatorAssignment")
  assignedOpportunitiesPM        Opportunity[] @relation("PMAssignment")
  ownedCustomers                 Customer[]    @relation("CustomerOwner")
  notes                          OpportunityNote[]
  goNoGoApprovals                GoNoGoDecisionRecord[] @relation("GoNoGoApprover")
  invitationsSent                Invitation[]  @relation("InvitedBy")
  auditLogs                      AuditLog[]
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])
  actorLabel  String?
  event       String
  targetType  String?
  targetId    String?
  ip          String?
  userAgent   String?
  meta        Json?
  createdAt   DateTime @default(now())

  @@index([event])
  @@index([userId])
  @@index([createdAt])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Invitation {
  id           Int      @id @default(autoincrement())
  token        String   @unique
  email        String
  fullName     String
  role         Role
  invitedById  Int?
  invitedBy    User?    @relation("InvitedBy", fields: [invitedById], references: [id])
  acceptedAt   DateTime?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([email])
}

model Customer {
  id              Int           @id @default(autoincrement())
  customerNumber  String?       @unique
  companyName     String
  primaryContact  String?
  phone           String?
  email           String?
  customerType    CustomerType  @default(GC)
  tier            RelationshipTier @default(NEW)
  lastLook        Boolean       @default(false)
  ownerId         Int?
  owner           User?         @relation("CustomerOwner", fields: [ownerId], references: [id])
  notes           String?
  isArchived      Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdById     Int?
  updatedById     Int?

  opportunities Opportunity[]
  contacts      Contact[]      @relation("ContactCurrent")
  complianceDocs ComplianceDoc[]
  aliases       CustomerAlias[]
}

model CustomerAlias {
  id          Int      @id @default(autoincrement())
  customerId  Int
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  alias       String
  normalized  String   // lowercased, suffix-stripped, punctuation-stripped form for lookup
  createdAt   DateTime @default(now())

  @@unique([customerId, alias])
  @@index([normalized])
}

model Opportunity {
  id                    Int            @id @default(autoincrement())
  projectNumber         String         @unique
  projectName           String
  customerName          String
  customerId            Int?
  customer              Customer?      @relation(fields: [customerId], references: [id])
  customerType          CustomerType   @default(GC)
  projectType           String
  region                String
  scopeOfWork           String[]       @default([])
  estimatedValueCents   BigInt         @default(0)
  actualValueCents      BigInt?
  winningBidCents       BigInt?
  bidMarginPct          Float          @default(6.0)
  expectedMarginPct     Float?
  bidDueDate            DateTime?
  estimatedStartDate    DateTime?
  estimatedDurationMonths Int?
  stage                 PipelineStage  @default(LEAD)
  pipelineBoard         String         @default("main")
  bondingRequired       Boolean        @default(false)
  bondAmountCents       BigInt?
  estimatorId           Int?
  estimator             User?          @relation("EstimatorAssignment", fields: [estimatorId], references: [id])
  pmId                  Int?
  pm                    User?          @relation("PMAssignment", fields: [pmId], references: [id])
  source                String?
  competitive           Boolean        @default(true)
  lastLook              Boolean        @default(false)
  lossReason            String?
  winningBidder         String?
  noBidReason           String?
  goNoGoScore           Float?
  goNoGoClientScore     Float?
  goNoGoProjectScore    Float?
  goNoGoCompetitionScore Float?
  goNoGoDecisionBand    String?
  pwin                  Float?
  heavyBidJobNumber     String?
  sage300JobNumber      String?
  costToDateCents       BigInt?
  billedToDateCents     BigInt?
  percentComplete       Float?
  actualMarginPct       Float?
  actualsAsOf           DateTime?
  backlogStatus         BacklogStatus  @default(ACTIVE)
  stageChangedAt        DateTime       @default(now())
  bidSubmittedAt        DateTime?
  decidedAt             DateTime?
  lastActivityAt        DateTime       @default(now())
  nextActionDate        DateTime?
  nextActionNote        String?

  isArchived            Boolean        @default(false)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  createdById           Int?
  updatedById           Int?

  notes               OpportunityNote[]
  stageHistory        StageHistory[]
  goNoGoDecisions     GoNoGoDecisionRecord[]

  @@index([stage])
  @@index([pipelineBoard])
  @@index([estimatorId])
  @@index([customerId])
  @@index([region])
  @@index([projectType])
  @@index([nextActionDate])
  @@index([lastActivityAt])
}

model SavedView {
  id          Int      @id @default(autoincrement())
  name        String
  scope       String   @default("PRIVATE") // PRIVATE | TEAM | ORG
  ownerId     Int?
  filtersJson String
  sortOrder   Int      @default(0)
  isPinned    Boolean  @default(false)
  page        String   @default("pipeline") // future-proof: views per page
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PipelineBoard {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  name      String
  color     String   @default("#8B1A1A")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
}

model AutomationRule {
  id          Int      @id @default(autoincrement())
  name        String
  trigger     String   // STAGE_CHANGED_TO | OPPORTUNITY_CREATED | NEXT_ACTION_OVERDUE
  triggerArg  String?  // e.g. stage name for STAGE_CHANGED_TO
  action      String   // CREATE_NOTE | SET_NEXT_ACTION | SEND_EMAIL_TEMPLATE
  actionArgs  String   // JSON
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ComplianceDoc {
  id          Int      @id @default(autoincrement())
  docType     String   // COI | W9 | LICENSE | MBE | WBE | DBE | OTHER
  label       String?
  customerId  Int?
  customer    Customer? @relation(fields: [customerId], references: [id])
  userId      Int?
  expiresAt   DateTime?
  notes       String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([expiresAt])
  @@index([customerId])
}

model Contact {
  id              Int      @id @default(autoincrement())
  fullName        String
  email           String?
  phone           String?
  title           String?
  currentCustomerId Int?
  currentCustomer Customer? @relation("ContactCurrent", fields: [currentCustomerId], references: [id])
  notes           String?
  isArchived      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employmentHistory ContactEmployment[]

  @@index([fullName])
  @@index([email])
  @@index([currentCustomerId])
}

model ContactEmployment {
  id          Int      @id @default(autoincrement())
  contactId   Int
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  customerId  Int?
  customerName String   // denormalized for resilience
  title       String?
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime @default(now())

  @@index([contactId])
}

model OpportunityNote {
  id            Int         @id @default(autoincrement())
  opportunityId Int
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  authorId      Int
  author        User        @relation(fields: [authorId], references: [id])
  body          String
  createdAt     DateTime    @default(now())
}

model StageHistory {
  id            Int            @id @default(autoincrement())
  opportunityId Int
  opportunity   Opportunity    @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  fromStage     PipelineStage?
  toStage       PipelineStage
  changedById   Int?
  changedAt     DateTime       @default(now())
}

model GoNoGoDecisionRecord {
  id                  Int             @id @default(autoincrement())
  opportunityId       Int
  opportunity         Opportunity     @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  marginScore         Int
  customerScore       Int
  geoScore            Int
  scopeRiskScore      Int
  resourceScore       Int
  bondRiskScore       Int
  strategicScore      Int
  compositeScore      Float
  decision            GoNoGoDecision
  approverId          Int?
  approver            User?           @relation("GoNoGoApprover", fields: [approverId], references: [id])
  conditions          String?
  createdAt           DateTime        @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model DropdownOption {
  id        Int      @id @default(autoincrement())
  category  String
  value     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)

  @@unique([category, value])
  @@index([category])
}

// ---- Phase 2 placeholder stubs (NOT yet built; reserved for future use) ----
model PostProjectReview {
  id              Int      @id @default(autoincrement())
  opportunityId   Int?
  estimatedMargin Float?
  actualMargin    Float?
  notes           String?
  createdAt       DateTime @default(now())
}

model IntegrationLog {
  id        Int      @id @default(autoincrement())
  source    String
  payload   String?
  status    String?
  createdAt DateTime @default(now())
}

model IntegrationImport {
  id          Int      @id @default(autoincrement())
  source      String   // HEAVYBID | SAGE300
  fileName    String?
  importedBy  Int?
  rowCount    Int      @default(0)
  createdCount Int     @default(0)
  updatedCount Int     @default(0)
  skippedCount Int     @default(0)
  errorCount  Int      @default(0)
  errorsJson  String?
  createdAt   DateTime @default(now())

  @@index([source])
  @@index([createdAt])
}
